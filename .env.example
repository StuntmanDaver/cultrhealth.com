# ============================================
# CULTR Health - Environment Variables Template
# ============================================

# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# ============================================
# STRIPE PAYMENT PROCESSING
# ============================================

# Stripe secret key (get from https://dashboard.stripe.com/apikeys)
# Use test keys for development: sk_test_...
# Use live keys for production: sk_live_...
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Stripe webhook secret (get from https://dashboard.stripe.com/webhooks)
# Used to verify webhook signatures
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# ============================================
# AUTHENTICATION & SECURITY
# ============================================

# JWT secret for token signing (generate a random 32+ character string)
JWT_SECRET=your-secure-jwt-secret-here

# Session secret for session management (generate a random 32+ character string)
SESSION_SECRET=your-secure-session-secret-here

# ============================================
# EMAIL (RESEND)
# ============================================

# Resend API key for sending transactional emails
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_API_KEY

# Email addresses for system communications
FROM_EMAIL=hello@cultrhealth.com
FOUNDER_EMAIL=founder@cultrhealth.com
SUPPORT_EMAIL=support@cultrhealth.com

# ============================================
# DATABASE (NEON/POSTGRES)
# ============================================

# Neon/Postgres connection string. This legacy repo still uses @vercel/postgres SDK;
# active Cloudflare repos use Cloudflare-compatible Neon access.
# Format: postgres://user:password@host:port/database
POSTGRES_URL=your-postgres-connection-string

# ============================================
# HEALTHIE EHR INTEGRATION
# ============================================

# Healthie API key for creating/linking paid signup patient records.
# If omitted, paid signup stores ehr_sync_status=pending and retries can link later.
HEALTHIE_API_KEY=your-healthie-api-key-here

# Healthie GraphQL API URL
# Production: https://api.gethealthie.com/graphql
# Staging: https://staging-api.gethealthie.com/graphql
HEALTHIE_API_URL=https://api.gethealthie.com/graphql

# Healthie webhook verification secret
HEALTHIE_WEBHOOK_SECRET=your-healthie-webhook-secret
# Enable Healthie integration (requires HEALTHIE_API_KEY)
USE_HEALTHIE=false

# ============================================
# XERO ACCOUNTING INTEGRATION (replaces QuickBooks)
# ============================================

# Xero OAuth2 app credentials (developer.xero.com → My Apps)
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
# Obtained during initial OAuth2 authorization flow
XERO_REFRESH_TOKEN=your-xero-refresh-token
# Organization/Tenant GUID from Xero (Connections → Organisations)
XERO_TENANT_ID=your-xero-tenant-id
# Webhook signing key from Xero developer portal → Webhooks
XERO_WEBHOOK_KEY=your-xero-webhook-key
# Enable Xero integration
USE_XERO=false

# QuickBooks (legacy — being replaced by Xero)
# Set USE_QUICKBOOKS=false once Xero is live
USE_QUICKBOOKS=false

# ============================================
# ZAPIER AUTOMATION
# ============================================

# Shared secret for Zapier inbound webhooks
# Set this in Zapier → Webhooks → Headers: Authorization: Bearer <value>
ZAPIER_WEBHOOK_SECRET=your-zapier-webhook-secret

# Zapier catch-hook URLs (outbound from CULTR → Zapier)
# Creator application event → Notion creator record
ZAPIER_CREATOR_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_ZAP_ID/creator
# Healthie payment/event signals → Notion tasks
ZAPIER_HEALTHIE_EVENT_URL=https://hooks.zapier.com/hooks/catch/YOUR_ZAP_ID/healthie
# Xero invoice events → Notion billing tasks
ZAPIER_XERO_EVENT_URL=https://hooks.zapier.com/hooks/catch/YOUR_ZAP_ID/xero

# ============================================
# SITE CONFIGURATION
# ============================================

# Public site URL (used for redirects and email links)
# Development: http://localhost:3000
# Staging: https://staging.cultrhealth.com
# Production: https://cultrhealth.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Calendly results-review event type. Configure the Calendly event with
# at least 14 days minimum notice; the webhook also flags early bookings.
NEXT_PUBLIC_CALENDLY_RESULTS_REVIEW_URL=https://calendly.com/cultr/results-review
CALENDLY_WEBHOOK_SECRET=your-calendly-webhook-secret

# ============================================
# CLOUDFLARE TURNSTILE (CAPTCHA)
# ============================================

# Cloudflare Turnstile secret key for bot protection
# Get from https://dash.cloudflare.com/turnstile
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ============================================
# UPSTASH REDIS (OPTIONAL)
# ============================================

# Upstash Redis for caching and rate limiting
# Get from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# ============================================
# ACCESS CONTROL
# ============================================

# Admin email - primary contact for club order approvals
ADMIN_APPROVAL_EMAIL=admin@cultrhealth.com

# Admin access control - comma-separated list of emails with admin panel access
ADMIN_ALLOWED_EMAILS=admin@cultrhealth.com,your-email@cultrhealth.com

# Admin secret key - legacy auth for order fulfillment API (used alongside session auth)
ADMIN_SECRET=your-admin-secret-key-here


# ============================================

# Provider access - comma-separated list of emails with protocol builder access
PROTOCOL_BUILDER_ALLOWED_EMAILS=provider@cultrhealth.com,doctor@cultrhealth.com

# Staging access - bypass Stripe subscription check for testing
# Comma-separated list of emails
STAGING_ACCESS_EMAILS=test1@example.com,test2@example.com

# ============================================
# ============================================
# CRON JOB SECURITY
# ============================================

# Secret token for authenticating scheduled cron requests
# Used by: /api/cron/approve-commissions, /api/cron/update-tiers
# Generate a random string (32+ chars)
CRON_SECRET=your-cron-secret-here

# ============================================
# COREPAY PAYMENT PROCESSING
# ============================================

NEXT_PUBLIC_ENABLE_COREPAY=false
COREPAY_ENVIRONMENT=sandbox
NEXT_PUBLIC_COREPAY_API_LOGIN_ID=your-corepay-api-login-id
NEXT_PUBLIC_COREPAY_PUBLIC_CLIENT_KEY=your-corepay-public-client-key
COREPAY_TRANSACTION_KEY=your-corepay-transaction-key

# ============================================
# SIPHOX HEALTH INTEGRATION (OPTIONAL)
# ============================================

# SiPhox API Bearer token for kit fulfillment, status sync, and lab results notifications
# SIPHOX_API_KEY=your-siphox-api-key

# Optional override for SiPhox API URL (defaults to production endpoint)
# SIPHOX_API_URL=https://connect.siphoxhealth.com/api/v1

# ============================================
# STRIPE BLOOD TEST ADD-ON (OPTIONAL)
# ============================================

# Stripe Price ID for the $135 at-home blood test kit add-on (Core tier)
# Create a one-time product/price in Stripe Dashboard, then set the price_xxx ID here
# BLOOD_TEST_STRIPE_PRICE_ID=price_xxx

# ============================================
# BNPL INTEGRATIONS (BUY NOW PAY LATER)
# ============================================

# Klarna (Sandbox Mode)
# Get credentials from https://portal.klarna.com/
KLARNA_API_KEY=YOUR_KLARNA_SANDBOX_API_KEY
KLARNA_API_SECRET=YOUR_KLARNA_SANDBOX_SECRET
KLARNA_API_URL=https://api.playground.klarna.com
NEXT_PUBLIC_KLARNA_CLIENT_ID=YOUR_KLARNA_CLIENT_ID

# Affirm (Sandbox Mode)
# Get credentials from https://www.affirm.com/dashboard/
AFFIRM_PRIVATE_API_KEY=YOUR_AFFIRM_SANDBOX_PRIVATE_KEY
NEXT_PUBLIC_AFFIRM_PUBLIC_KEY=YOUR_AFFIRM_SANDBOX_PUBLIC_KEY
AFFIRM_API_URL=https://sandbox.affirm.com
NEXT_PUBLIC_AFFIRM_SCRIPT_URL=https://cdn1-sandbox.affirm.com/js/v2/affirm.js

# BNPL Feature Flags
NEXT_PUBLIC_ENABLE_KLARNA=true
NEXT_PUBLIC_ENABLE_AFFIRM=true
