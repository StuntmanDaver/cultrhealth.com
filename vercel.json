{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": false,
      "master": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/approve-commissions",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/update-tiers",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/stale-orders",
      "schedule": "0 12 * * *"
    }
  ]
}
